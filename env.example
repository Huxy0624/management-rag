# Core runtime
GENERATION_RUNTIME_PROFILE=production
ENABLE_LLM_SURFACE_GENERATION_V3=true
ENABLE_CONTROL_CHECKS=true
ENABLE_REWRITE_V3=true
ENABLE_FALLBACK_V21=true
DEBUG_RETURN_INTERMEDIATE=false

# OpenAI
OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_SECONDS=60
# OPENAI_MAX_RETRIES=2

# External demo
DEMO_DEBUG_TOKEN=replace-with-debug-token
DEMO_ADMIN_TOKEN=replace-with-admin-token
DEMO_SHOW_DEBUG_TOGGLE=true
DEMO_RATE_LIMIT_WINDOW_SECONDS=60
DEMO_RATE_LIMIT_MAX_REQUESTS=12

# Optional copy overrides
# DEMO_TITLE=TraceAnswer
# DEMO_TAGLINE=An AI Q&A demo that makes retrieval, controlled generation, and fallback behavior easier to inspect.
# DEMO_DESCRIPTION=This demo combines retrieval, planner-based generation, controlled answering, and fallback safeguards into a single shareable experience.
# DEMO_EXAMPLES=什么是跨部门协作问题？||为什么跨部门协作经常低效？||怎么临时推进跨部门合作？
